{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "id": {
                "type": "string",
                "description": "Unique role identifier (camelCase)"
            },
            "name": {
                "type": "string",
                "description": "Display name"
            },
            "description": {
                "type": "string",
                "description": "Purpose of the role"
            },
            "permissions": {
                "type": "array",
                "items": {
                    "type": "string"
                },
                "description": "Logical permissions list"
            }
        },
        "required": [
            "id",
            "name",
            "description",
            "permissions"
        ]
    }
}