# ==========================================
# Attendance Intelligence Platform
# Environment Configuration Example
# ==========================================

# Server Configuration
PORT=8080
CLIENT_ORIGIN=http://localhost:5173

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendance_intelligence
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# ==========================================
# Authentication Mode
# ==========================================
# Options: "api" (legacy), "keycloak" (OIDC/SAML)
# Use "api" for traditional email/password with session tokens
# Use "keycloak" for OIDC authentication via Keycloak
AUTH_MODE=api

# ==========================================
# Legacy Token Settings (only used when AUTH_MODE=api)
# ==========================================
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7

# ==========================================
# Keycloak Configuration (required when AUTH_MODE=keycloak)
# ==========================================

# Keycloak Server URL
KEYCLOAK_URL=http://localhost:9090

# Keycloak Realm Name
KEYCLOAK_REALM=attendance

# Keycloak Issuer URL (usually {KEYCLOAK_URL}/realms/{KEYCLOAK_REALM})
KEYCLOAK_ISSUER=http://localhost:9090/realms/attendance

# Keycloak Audience (resource server identifier)
# This should match the "audience" configured in Keycloak client
KEYCLOAK_AUDIENCE=attendance-api

# Keycloak JWKS URI for token signature verification
# Usually {KEYCLOAK_URL}/realms/{KEYCLOAK_REALM}/protocol/openid-connect/certs
KEYCLOAK_JWKS_URI=http://localhost:9090/realms/attendance/protocol/openid-connect/certs

# Clock tolerance for JWT validation (in seconds)
# Allows for minor time differences between servers
KEYCLOAK_CLOCK_TOLERANCE_SEC=5

# ==========================================
# Frontend Environment Variables (Vite)
# ==========================================
# These should be set in a .env file in the frontend root or
# passed as build arguments

# VITE_AUTH_MODE=mock
# VITE_API_BASE_URL=http://localhost:8080/api
# VITE_KEYCLOAK_URL=http://localhost:9090
# VITE_KEYCLOAK_REALM=attendance
# VITE_KEYCLOAK_CLIENT_ID=attendance-frontend
