PORT=8080
CLIENT_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_NAME=FRS
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

EDGE_AI_URL=http://localhost:5000

ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7

# Auth mode: 'api' or 'keycloak'
AUTH_MODE=api

# Keycloak config (only needed when AUTH_MODE=keycloak)
KEYCLOAK_URL=http://localhost:9090
KEYCLOAK_REALM=attendance

# Optional: Google Calendar API key for fetching public holidays
# If not provided, the system will use a limited set of fallback holidays
# Get your API key from: https://developers.google.com/calendar/api/quickstart/js
# GOOGLE_CALENDAR_API_KEY=your_api_key_here
