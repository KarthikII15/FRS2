{
  "title": "FRS2 - Device Health",
  "tags": ["frs2", "devices", "health"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Jetson CPU Usage",
      "type": "graph",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [{
        "expr": "jetson_cpu_usage_percent",
        "legendFormat": "CPU %",
        "refId": "A"
      }],
      "yaxes": [
        {"format": "percent", "label": "CPU %", "max": 100, "min": 0},
        {"format": "short"}
      ]
    },
    {
      "id": 2,
      "title": "Jetson Memory Usage",
      "type": "graph",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "jetson_memory_used_mb",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "jetson_memory_total_mb",
          "legendFormat": "Total",
          "refId": "B"
        }
      ],
      "yaxes": [
        {"format": "mbytes", "label": "Memory"},
        {"format": "short"}
      ]
    },
    {
      "id": 3,
      "title": "Jetson Temperature",
      "type": "graph",
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 6},
      "targets": [{
        "expr": "jetson_temperature_celsius",
        "legendFormat": "GPU Temp",
        "refId": "A"
      }],
      "yaxes": [
        {"format": "celsius", "label": "Temperature"},
        {"format": "short"}
      ]
    },
    {
      "id": 4,
      "title": "Jetson Disk Usage",
      "type": "gauge",
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 6},
      "targets": [{
        "expr": "jetson_disk_used_gb",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 80, "color": "yellow"},
              {"value": 120, "color": "red"}
            ]
          },
          "max": 150
        }
      }
    },
    {
      "id": 5,
      "title": "FRS Service Status",
      "type": "stat",
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 6},
      "targets": [{
        "expr": "jetson_frs_service_running",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "value": 0, "text": "Stopped"},
            {"type": "value", "value": 1, "text": "Running"}
          ],
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 1, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Backend Memory Usage",
      "type": "graph",
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
      "targets": [{
        "expr": "process_resident_memory_bytes{job=\"frs-backend\"}",
        "legendFormat": "Backend Memory",
        "refId": "A"
      }],
      "yaxes": [
        {"format": "bytes", "label": "Memory"},
        {"format": "short"}
      ]
    },
    {
      "id": 7,
      "title": "PostgreSQL Connections",
      "type": "graph",
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 8},
      "targets": [{
        "expr": "pg_stat_database_numbackends{datname=\"attendance_intelligence\"}",
        "legendFormat": "Active Connections",
        "refId": "A"
      }],
      "yaxes": [
        {"format": "short", "label": "Connections"},
        {"format": "short"}
      ]
    }
  ]
}
